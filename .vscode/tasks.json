{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run frontend",
			"type": "npm",
			"script": "dev",
			"path": "frontend",
			"problemMatcher": [
				{
					"pattern": [
						{
							"regexp": ".",
							"file": 1,
							"location": 2,
							"message": 3
						}
					],
					"background": {
						"activeOnStart": true,
						"beginsPattern": ".*VITE.*",
						"endsPattern": ".*ready in.*|.*Local:.*"
					}
				}
			],
			"detail": "vite",
			"isBackground": true
		},
		{
			"label": "Stop Front End Vite Server",
			"type": "shell",
			"command": "echo ${input:terminateVite}",
			"presentation": {
				"close": true,
				"showReuseMessage": false
			},
			"problemMatcher": []
		}
	],
	"inputs": [
		{
			"id": "terminateVite",
			"type": "command",
			"command": "workbench.action.tasks.terminate",
			"args": "Run frontend"
		}
	]
}
