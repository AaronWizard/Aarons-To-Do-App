{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run AaronsToDoApp.FrontEnd",
			"type": "npm",
			"script": "dev",
			"path": "AaronsToDoApp.FrontEnd",
			"problemMatcher": [
				{
					"pattern": [
						{
							"regexp": ".",
							"file": 1,
							"location": 2,
							"message": 3
						}
					],
					"background": {
						"activeOnStart": true,
						"beginsPattern": ".*VITE.*",
						"endsPattern": ".*ready in.*|.*Local:.*"
					}
				}
			],
			"detail": "vite",
			"isBackground": true
		}
	]
}
